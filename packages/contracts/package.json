{
    "name": "@starter/contracts",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "main": "./dist/index.cjs",
    "module": "./dist/index.mjs",
    "types": "./src/index.ts",
    "exports": {
        ".": {
            "types": "./src/index.ts",
            "import": "./src/index.ts",
            "require": "./dist/index.cjs"
        }
    },
    "scripts": {
        "build": "tsdown src/index.ts --format esm,cjs --dts --clean",
        "dev": "tsdown src/index.ts --format esm,cjs --dts --watch --clean",
        "typecheck": "tsc --noEmit",
        "test": "vitest run --passWithNoTests"
    },
    "dependencies": {
        "zod": "^3.24.0"
    },
    "devDependencies": {
        "tsdown": "^0.20.3",
        "typescript": "^5.7.3",
        "vitest": "^4.0.0"
    }
}

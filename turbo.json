{
    "$schema": "https://turbo.build/schema.json",
    "tasks": {
        "build": {
            "dependsOn": [
                "^build"
            ],
            "outputs": [
                "dist/**"
            ]
        },
        "dev": {
            "dependsOn": [
                "@starter/contracts#build"
            ],
            "cache": false,
            "persistent": true
        },
        "typecheck": {
            "dependsOn": [
                "^typecheck"
            ],
            "outputs": [],
            "cache": false
        },
        "test": {
            "dependsOn": [
                "^build"
            ],
            "cache": false
        },
        "lint": {
            "cache": false
        },
        "db:generate": {
            "cache": false
        },
        "db:migrate": {
            "cache": false
        }
    }
}

{
    "name": "@starter/server",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "bun run --hot src/index.ts",
        "build": "tsdown src/index.ts --format esm --clean",
        "start": "bun run dist/index.mjs",
        "typecheck": "tsc --noEmit",
        "test": "vitest run --passWithNoTests",
        "db:generate": "drizzle-kit generate",
        "db:migrate": "bun run src/db/migrate.ts"
    },
    "dependencies": {
        "@hono/node-server": "^1.14.4",
        "@hono/trpc-server": "^0.4.0",
        "@starter/contracts": "workspace:*",
        "@starter/shared": "workspace:*",
        "@trpc/server": "^11.0.0",
        "drizzle-orm": "^0.38.0",
        "hono": "^4.8.2",
        "zod": "^3.24.0"
    },
    "devDependencies": {
        "@types/bun": "^1.3.9",
        "drizzle-kit": "^0.30.0",
        "tsdown": "^0.20.3",
        "typescript": "^5.7.3",
        "vitest": "^4.0.0"
    }
}
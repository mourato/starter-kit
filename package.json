{
    "name": "@starter/monorepo",
    "private": true,
    "workspaces": [
        "apps/*",
        "packages/*"
    ],
    "type": "module",
    "scripts": {
        "dev": "turbo run dev",
        "dev:server": "turbo run dev --filter=@starter/server",
        "dev:web": "turbo run dev --filter=@starter/web",
        "build": "turbo run build",
        "typecheck": "turbo run typecheck",
        "lint": "oxlint --report-unused-disable-directives",
        "fmt": "oxfmt",
        "test": "turbo run test",
        "clean": "rm -rf node_modules apps/*/node_modules packages/*/node_modules apps/*/dist packages/*/dist .turbo apps/*/.turbo packages/*/.turbo",
        "db:generate": "turbo run db:generate --filter=@starter/server",
        "db:migrate": "turbo run db:migrate --filter=@starter/server"
    },
    "devDependencies": {
        "oxfmt": "^0.35.0",
        "oxlint": "^1.50.0",
        "turbo": "^2.3.3",
        "vitest": "^4.0.0"
    },
    "packageManager": "bun@1.3.9"
}
